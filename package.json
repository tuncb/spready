{
  "name": "spready",
  "productName": "Spready",
  "version": "0.0.7",
  "description": "Lean Electron Forge shell",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:mcp:cli": "node scripts/build-mcp-cli.mjs",
    "prepare:release": "node scripts/prepare-release-bundle.mjs",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/*.test.ts",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "mcp:stdio": "tsx src/mcp-stdio.ts"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "41.2.1",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "electron-squirrel-startup": "^1.0.1",
    "lodash": "^4.18.1",
    "marked": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-responsive-carousel": "^3.2.23",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
