{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src", "forge.config.ts", "vite.*.config.ts", "forge.env.d.ts"]
}
